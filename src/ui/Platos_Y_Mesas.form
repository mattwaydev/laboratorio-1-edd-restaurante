                      <Font name="Sitka Text" size="14" style="1"/>
                    </Property>
                    <Property name="rows" type="int" value="5"/>
                    <Property name="text" type="java.lang.String" value="Bienvenido a nuestra&#xa;experiencia  gastron&#xf3;mica. &#xa;En este espacio podr&#xe1;s &#xa;explorar los exquisitos &#xa;platos que nuestra cocina &#xa;tiene para ofrecerte, &#xa;elaborados con &#xa;ingredientes frescos y de &#xa;la m&#xe1;s alta calidad. &#xa;Adem&#xe1;s, podr&#xe1;s consultar&#xa; en tiempo real el estado&#xa; de nuestras mesas, &#xa;identificando f&#xe1;cilmente &#xa;cu&#xe1;les se encuentran &#xa;disponibles para que tu &#xa;velada comience con la &#xa;comodidad y atenci&#xf3;n que &#xa;mereces."/>
                  </Properties>
                </Component>
              </SubComponents>
            </Container>
          </SubComponents>
